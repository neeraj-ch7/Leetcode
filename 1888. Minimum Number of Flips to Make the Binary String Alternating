class Solution {
    public int minFlips(String s) {
        int n = s.length();
        String str = s + s;

        StringBuilder s1 = new StringBuilder();
        StringBuilder s2 = new StringBuilder();

        // build alternating patterns
        for (int i = 0; i < 2 * n; i++) {
            if (i % 2 == 0) {
                s1.append('0');
                s2.append('1');
            } else {
                s1.append('1');
                s2.append('0');
            }
        }

        int ans = Integer.MAX_VALUE;
        int d1 = 0, d2 = 0;
        int l = 0;

        for (int r = 0; r < 2 * n; r++) {

            if (str.charAt(r) != s1.charAt(r)) d1++;
            if (str.charAt(r) != s2.charAt(r)) d2++;

            if (r - l + 1 > n) {
                if (str.charAt(l) != s1.charAt(l)) d1--;
                if (str.charAt(l) != s2.charAt(l)) d2--;
                l++;
            }

            if (r - l + 1 == n) {
                ans = Math.min(ans, Math.min(d1, d2));
            }
        }

        return ans;
    }
}
